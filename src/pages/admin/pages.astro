</p>


<br>




<div class="page-list">


{

pages.length === 0 ? (

	<p>
		No pages found.
	</p>

) : (


	pages.map(page => (

		<div class="page-card">


			<span>

				📄 {page}

			</span>



			<a

				class="button"

				href={`/admin/edit/${page}`}

			>

				Edit

			</a>


		</div>

	))


)

}


</div>



<br>



<a class="button" href="/admin/dashboard">

	← Back to Dashboard

</a>

so 

</div>


</div>


</body>


</html>